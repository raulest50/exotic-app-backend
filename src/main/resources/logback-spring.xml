<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <include resource="org/springframework/boot/logging/logback/defaults.xml"/>


    <!-- Niveles de logging:
    TRACE (mas detallado),
     DEBUG (depuracion),
      INFO (general),
       WARN (advertencias),
        ERROR (errores),
         OFF (desactivado) -->

    <!-- Variables de configuracion de logging -->
    <property name="FLYWAY_LOG_LEVEL" value="OFF"/>

    <property name="DB_LOG_LEVEL" value="OFF"/>

    <property name="BACKUP_TOTAL_EXPORT_LOG_LEVEL" value="DEBUG"/>
    <property name="BACKUP_TOTAL_IMPORT_FILE_LOG_LEVEL" value="DEBUG"/>

    <!-- Appender de consola para ver todos los logs -->
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level %logger{36} - %msg%n</pattern>
            <charset>UTF-8</charset>
        </encoder>
    </appender>

    <!-- Loggers para Flyway -->
    <logger name="org.flywaydb" level="${FLYWAY_LOG_LEVEL}" additivity="false">
        <appender-ref ref="CONSOLE"/>
    </logger>
    <logger name="org.flywaydb.core" level="${FLYWAY_LOG_LEVEL}" additivity="false">
        <appender-ref ref="CONSOLE"/>
    </logger>
    <logger name="org.springframework.boot.autoconfigure.flyway" level="${FLYWAY_LOG_LEVEL}" additivity="false">
        <appender-ref ref="CONSOLE"/>
    </logger>

    <!-- Logger para ver errores de conexion a BD -->
    <logger name="org.springframework.jdbc" level="${DB_LOG_LEVEL}" additivity="false">
        <appender-ref ref="CONSOLE"/>
    </logger>
    <logger name="com.zaxxer.hikari" level="${DB_LOG_LEVEL}" additivity="false">
        <appender-ref ref="CONSOLE"/>
    </logger>

    <!-- Root logger con salida a consola -->
    <root level="INFO">
        <appender-ref ref="CONSOLE"/>
    </root>

    <!-- Appender para logs de carga masiva (archivo dedicado para diagnostico) -->
    <property name="LOG_PATH" value="logs"/>

    <springProfile name="login-diagnostics">
        <springProperty scope="context" name="LOGIN_DIAGNOSTIC_APP_LEVEL" source="LOGIN_DIAGNOSTIC_APP_LEVEL" defaultValue="DEBUG"/>
        <springProperty scope="context" name="LOGIN_DIAGNOSTIC_SECURITY_LEVEL" source="LOGIN_DIAGNOSTIC_SECURITY_LEVEL" defaultValue="TRACE"/>
        <springProperty scope="context" name="LOGIN_DIAGNOSTIC_WEB_LEVEL" source="LOGIN_DIAGNOSTIC_WEB_LEVEL" defaultValue="DEBUG"/>
        <springProperty scope="context" name="LOGIN_DIAGNOSTIC_DB_LEVEL" source="LOGIN_DIAGNOSTIC_DB_LEVEL" defaultValue="DEBUG"/>
        <springProperty scope="context" name="LOGIN_DIAGNOSTIC_SQL_LEVEL" source="LOGIN_DIAGNOSTIC_SQL_LEVEL" defaultValue="DEBUG"/>
        <springProperty scope="context" name="LOGIN_DIAGNOSTIC_SQL_BIND_LEVEL" source="LOGIN_DIAGNOSTIC_SQL_BIND_LEVEL" defaultValue="TRACE"/>

        <appender name="LOGIN_TROUBLESHOOTING_FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
            <file>${LOG_PATH}/login_troubleshooting.log</file>
            <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
                <fileNamePattern>${LOG_PATH}/login_troubleshooting.%d{yyyy-MM-dd}.%i.log</fileNamePattern>
                <maxFileSize>10MB</maxFileSize>
                <maxHistory>3</maxHistory>
                <totalSizeCap>50MB</totalSizeCap>
            </rollingPolicy>
            <encoder>
                <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level %logger{100} - %msg%n%xEx{full}</pattern>
                <charset>UTF-8</charset>
            </encoder>
        </appender>

        <logger name="exotic.app.planta.resource.users" level="${LOGIN_DIAGNOSTIC_APP_LEVEL}" additivity="false">
            <appender-ref ref="LOGIN_TROUBLESHOOTING_FILE"/>
        </logger>
        <logger name="exotic.app.planta.service.users" level="${LOGIN_DIAGNOSTIC_APP_LEVEL}" additivity="false">
            <appender-ref ref="LOGIN_TROUBLESHOOTING_FILE"/>
        </logger>
        <logger name="exotic.app.planta.security" level="${LOGIN_DIAGNOSTIC_APP_LEVEL}" additivity="false">
            <appender-ref ref="LOGIN_TROUBLESHOOTING_FILE"/>
        </logger>

        <logger name="org.springframework.security" level="${LOGIN_DIAGNOSTIC_SECURITY_LEVEL}" additivity="false">
            <appender-ref ref="LOGIN_TROUBLESHOOTING_FILE"/>
        </logger>
        <logger name="org.springframework.web" level="${LOGIN_DIAGNOSTIC_WEB_LEVEL}" additivity="false">
            <appender-ref ref="LOGIN_TROUBLESHOOTING_FILE"/>
        </logger>
        <logger name="org.springframework.web.servlet.DispatcherServlet" level="${LOGIN_DIAGNOSTIC_WEB_LEVEL}" additivity="false">
            <appender-ref ref="LOGIN_TROUBLESHOOTING_FILE"/>
        </logger>
        <logger name="org.springframework.web.cors" level="${LOGIN_DIAGNOSTIC_WEB_LEVEL}" additivity="false">
            <appender-ref ref="LOGIN_TROUBLESHOOTING_FILE"/>
        </logger>

        <logger name="com.zaxxer.hikari" level="${LOGIN_DIAGNOSTIC_DB_LEVEL}" additivity="false">
            <appender-ref ref="LOGIN_TROUBLESHOOTING_FILE"/>
        </logger>
        <logger name="org.postgresql" level="${LOGIN_DIAGNOSTIC_DB_LEVEL}" additivity="false">
            <appender-ref ref="LOGIN_TROUBLESHOOTING_FILE"/>
        </logger>
        <logger name="org.springframework.jdbc" level="${LOGIN_DIAGNOSTIC_DB_LEVEL}" additivity="false">
            <appender-ref ref="LOGIN_TROUBLESHOOTING_FILE"/>
        </logger>
        <logger name="org.springframework.transaction" level="${LOGIN_DIAGNOSTIC_DB_LEVEL}" additivity="false">
            <appender-ref ref="LOGIN_TROUBLESHOOTING_FILE"/>
        </logger>
        <logger name="org.springframework.dao" level="${LOGIN_DIAGNOSTIC_DB_LEVEL}" additivity="false">
            <appender-ref ref="LOGIN_TROUBLESHOOTING_FILE"/>
        </logger>
        <logger name="org.hibernate.engine.jdbc.spi.SqlExceptionHelper" level="${LOGIN_DIAGNOSTIC_DB_LEVEL}" additivity="false">
            <appender-ref ref="LOGIN_TROUBLESHOOTING_FILE"/>
        </logger>

        <logger name="org.hibernate.SQL" level="${LOGIN_DIAGNOSTIC_SQL_LEVEL}" additivity="false">
            <appender-ref ref="LOGIN_TROUBLESHOOTING_FILE"/>
        </logger>
        <logger name="org.hibernate.orm.jdbc.bind" level="${LOGIN_DIAGNOSTIC_SQL_BIND_LEVEL}" additivity="false">
            <appender-ref ref="LOGIN_TROUBLESHOOTING_FILE"/>
        </logger>
        <logger name="org.hibernate.type.descriptor.sql.BasicBinder" level="${LOGIN_DIAGNOSTIC_SQL_BIND_LEVEL}" additivity="false">
            <appender-ref ref="LOGIN_TROUBLESHOOTING_FILE"/>
        </logger>
    </springProfile>

    <appender name="CARGA_MASIVA_FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${LOG_PATH}/carga_masiva.log</file>
        <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
            <fileNamePattern>${LOG_PATH}/carga_masiva.%d{yyyy-MM-dd}.log</fileNamePattern>
            <maxHistory>7</maxHistory>
        </rollingPolicy>
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level %logger{36} - %msg%n%ex</pattern>
            <charset>UTF-8</charset>
        </encoder>
    </appender>

    <appender name="ELIMINACION_FORZADA_FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${LOG_PATH}/eliminaciones_forzadas.log</file>
        <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
            <fileNamePattern>${LOG_PATH}/eliminaciones_forzadas.%d{yyyy-MM-dd}.log</fileNamePattern>
            <maxHistory>14</maxHistory>
        </rollingPolicy>
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level %logger{60} - %msg%n%ex</pattern>
            <charset>UTF-8</charset>
        </encoder>
    </appender>

    <appender name="PLANEACION_EXCEL_DEBUG_FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${LOG_PATH}/planeacion_excel_debug.log</file>
        <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
            <fileNamePattern>${LOG_PATH}/planeacion_excel_debug.%d{yyyy-MM-dd}.log</fileNamePattern>
            <maxHistory>14</maxHistory>
        </rollingPolicy>
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level %logger{80} - %msg%n%ex</pattern>
            <charset>UTF-8</charset>
        </encoder>
    </appender>

    <appender name="INGRESO_OCM_DIAGNOSTICO_FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${LOG_PATH}/ingreso_ocm_diagnostico.log</file>
        <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
            <fileNamePattern>${LOG_PATH}/ingreso_ocm_diagnostico.%d{yyyy-MM-dd}.log</fileNamePattern>
            <maxHistory>14</maxHistory>
        </rollingPolicy>
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level %logger{80} - %msg%n%ex</pattern>
            <charset>UTF-8</charset>
        </encoder>
    </appender>


    <appender name="BACKUP_TOTAL_EXPORT_FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${LOG_PATH}/backup_total_export.log</file>
        <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
            <fileNamePattern>${LOG_PATH}/backup_total_export.%d{yyyy-MM-dd}.log</fileNamePattern>
            <maxHistory>14</maxHistory>
        </rollingPolicy>
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level %logger{80} - %msg%n%ex</pattern>
            <charset>UTF-8</charset>
        </encoder>
    </appender>

    <appender name="BACKUP_TOTAL_IMPORT_FILE" class="ch.qos.logback.core.FileAppender">
        <file>${LOG_PATH}/backup_total_import.log</file>
        <append>false</append>
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level %logger{80} - %msg%n%ex</pattern>
            <charset>UTF-8</charset>
        </encoder>
    </appender>

    <logger name="exotic.app.planta.resource.commons.ExportacionDatosResource" level="${BACKUP_TOTAL_EXPORT_LOG_LEVEL}" additivity="false">
        <appender-ref ref="BACKUP_TOTAL_EXPORT_FILE"/>
        <appender-ref ref="CONSOLE"/>
    </logger>

    <logger name="exotic.app.planta.service.commons.BackupTotalExportService" level="${BACKUP_TOTAL_EXPORT_LOG_LEVEL}" additivity="false">
        <appender-ref ref="BACKUP_TOTAL_EXPORT_FILE"/>
        <appender-ref ref="CONSOLE"/>
    </logger>

    <logger name="exotic.app.planta.service.commons.PgDumpExecutableResolver" level="${BACKUP_TOTAL_EXPORT_LOG_LEVEL}" additivity="false">
        <appender-ref ref="BACKUP_TOTAL_EXPORT_FILE"/>
        <appender-ref ref="BACKUP_TOTAL_IMPORT_FILE"/>
        <appender-ref ref="CONSOLE"/>
    </logger>

    <logger name="exotic.app.planta.resource.commons.ImportacionDatosResource" level="${BACKUP_TOTAL_IMPORT_FILE_LOG_LEVEL}" additivity="false">
        <appender-ref ref="BACKUP_TOTAL_IMPORT_FILE"/>
        <appender-ref ref="CONSOLE"/>
    </logger>

    <logger name="exotic.app.planta.service.commons.BackupTotalImportService" level="${BACKUP_TOTAL_IMPORT_FILE_LOG_LEVEL}" additivity="false">
        <appender-ref ref="BACKUP_TOTAL_IMPORT_FILE"/>
        <appender-ref ref="CONSOLE"/>
    </logger>

    <logger name="exotic.app.planta.service.commons.DatabasePurgeService" level="${BACKUP_TOTAL_IMPORT_FILE_LOG_LEVEL}" additivity="false">
        <appender-ref ref="BACKUP_TOTAL_IMPORT_FILE"/>
        <appender-ref ref="CONSOLE"/>
    </logger>

    <logger name="org.postgresql" level="WARN" additivity="false">
        <appender-ref ref="BACKUP_TOTAL_EXPORT_FILE"/>
        <appender-ref ref="BACKUP_TOTAL_IMPORT_FILE"/>
        <appender-ref ref="CONSOLE"/>
    </logger>

    <logger name="org.hibernate.engine.jdbc.spi.SqlExceptionHelper" level="WARN" additivity="false">
        <appender-ref ref="BACKUP_TOTAL_EXPORT_FILE"/>
        <appender-ref ref="BACKUP_TOTAL_IMPORT_FILE"/>
        <appender-ref ref="CONSOLE"/>
    </logger>

    <logger name="org.springframework.dao" level="ERROR" additivity="false">
        <appender-ref ref="BACKUP_TOTAL_EXPORT_FILE"/>
        <appender-ref ref="BACKUP_TOTAL_IMPORT_FILE"/>
        <appender-ref ref="CONSOLE"/>
    </logger>







    <!-- Logger especifico para carga masiva -->
    <logger name="exotic.app.planta.resource.commons.CargaMasivaResource" level="DEBUG" additivity="true">
        <appender-ref ref="CARGA_MASIVA_FILE"/>
    </logger>
    <logger name="exotic.app.planta.service.commons.CargaMasivaService" level="DEBUG" additivity="true">
        <appender-ref ref="CARGA_MASIVA_FILE"/>
    </logger>
    <logger name="exotic.app.planta.service.inventarios.MovimientosService" level="DEBUG" additivity="true">
        <appender-ref ref="CARGA_MASIVA_FILE"/>
    </logger>
    <logger name="exotic.app.planta.service.commons.CargaMasivaTerminadoService" level="DEBUG" additivity="true">
        <appender-ref ref="CARGA_MASIVA_FILE"/>
    </logger>
    <logger name="exotic.app.planta.resource.commons.CargaMasivaTerminadoResource" level="DEBUG" additivity="true">
        <appender-ref ref="CARGA_MASIVA_FILE"/>
    </logger>

    <logger name="exotic.app.planta.resource.commons.EliminacionesForzadasResource" level="DEBUG" additivity="true">
        <appender-ref ref="ELIMINACION_FORZADA_FILE"/>
    </logger>
    <logger name="exotic.app.planta.service.commons.EliminacionesForzadasService" level="DEBUG" additivity="true">
        <appender-ref ref="ELIMINACION_FORZADA_FILE"/>
    </logger>


    <logger name="exotic.app.planta.resource.produccion.PlaneacionProduccionDebugResource" level="DEBUG" additivity="true">
        <appender-ref ref="PLANEACION_EXCEL_DEBUG_FILE"/>
        <appender-ref ref="CONSOLE"/>
    </logger>
    <logger name="exotic.app.planta.service.produccion.PlaneacionExcelDebugService" level="DEBUG" additivity="true">
        <appender-ref ref="PLANEACION_EXCEL_DEBUG_FILE"/>
        <appender-ref ref="CONSOLE"/>
    </logger>

    <logger name="exotic.app.planta.service.inventarios.IngresoAlmacenService" level="INFO" additivity="true">
        <appender-ref ref="INGRESO_OCM_DIAGNOSTICO_FILE"/>
    </logger>
    <logger name="exotic.app.planta.service.compras.ComprasService" level="INFO" additivity="true">
        <appender-ref ref="INGRESO_OCM_DIAGNOSTICO_FILE"/>
    </logger>
</configuration>
