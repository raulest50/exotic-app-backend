ENABLE_MCP=true
MCP_BIND_HOST=127.0.0.1
MCP_PORT=8765

# Comando completo que levantara el MCP.
# Debe respetar MCP_BIND_HOST y MCP_PORT, ya sea leyendo esas variables
# o embebiendo un bind localhost equivalente.
MCP_COMMAND=npx -y your-mcp-package --host "$MCP_BIND_HOST" --port "$MCP_PORT"

# Opcional: instalar un paquete global de npm durante el build de la imagen.
# Se configura como build-arg MCP_NPM_PACKAGE en Docker.
# MCP_NPM_PACKAGE=@your-scope/your-mcp-package
